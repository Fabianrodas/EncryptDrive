<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root"
            minHeight="600.0"
            minWidth="1000.0"
            prefHeight="600.0"
            prefWidth="1000.0"
            styleClass="window-root"
            stylesheets="@../css/login.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fabianrodas.encryptdrive.LoginController">

    <top>
        <HBox id="titleBar"
              alignment="CENTER_RIGHT"
              onMouseDragged="#dragWindow"
              onMousePressed="#beginDrag"
              prefHeight="38.0">

            <children>
                <Label styleClass="window-name" text="EncryptDrive" />

                <Region HBox.hgrow="ALWAYS" />

                <Button id="minimize"
                        focusTraversable="false"
                        mnemonicParsing="false"
                        onAction="#minimize"
                        styleClass="window-control"
                        text="−" />

                <Button id="maximize"
                        focusTraversable="false"
                        mnemonicParsing="false"
                        onAction="#toggleMaximize"
                        styleClass="window-control"
                        text="□" />

                <Button id="close"
                        focusTraversable="false"
                        mnemonicParsing="false"
                        onAction="#close"
                        styleClass="window-control"
                        text="×" />
            </children>
        </HBox>
    </top>

    <center>
        <GridPane maxHeight="1.7976931348623157E308">

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="42.0" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="58.0" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>

            <children>
                <StackPane GridPane.columnIndex="0"
                           maxHeight="1.7976931348623157E308"
                           styleClass="brand-pane">

                    <children>
                        <VBox alignment="CENTER"
                              maxWidth="340.0"
                              spacing="17.0"
                              styleClass="brand-content">

                            <children>
                                <StackPane styleClass="logo-badge">
                                    <children>
                                        <ImageView fitHeight="138.0"
                                                   fitWidth="138.0"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../images/logo.png" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </StackPane>

                                <Label styleClass="brand-title"
                                       text="EncryptDrive" />

                                <Label maxWidth="280.0"
                                       styleClass="brand-description"
                                       text="Local protection for your personal files and private workspace."
                                       textAlignment="CENTER"
                                       wrapText="true" />

                                <Label styleClass="brand-note"
                                       text="LOCAL • PRIVATE • PORTABLE" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <StackPane GridPane.columnIndex="1"
                           maxHeight="1.7976931348623157E308"
                           styleClass="auth-pane">

                    <children>
                        <VBox fx:id="formCard"
                            alignment="TOP_LEFT"
                            maxHeight="-Infinity"
                            maxWidth="560.0"
                            prefWidth="410.0"
                            spacing="14.0"
                            styleClass="form-card"
                            StackPane.alignment="CENTER">

                            <children>
                                <Label styleClass="headline"
                                       text="Welcome back" />

                                <Label styleClass="subheadline"
                                       text="Log in to access your EncryptDrive workspace."
                                       wrapText="true" />

                                <VBox spacing="7.0">
                                    <children>
                                        <Label styleClass="field-label"
                                               text="Username" />

                                        <TextField fx:id="usernameField"
                                                   promptText="Enter your username"
                                                   styleClass="input-field" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0">
                                    <children>
                                        <Label styleClass="field-label"
                                               text="Password" />

                                        <HBox alignment="CENTER_LEFT"
                                              spacing="8.0">

                                            <children>
                                                <StackPane HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <TextField fx:id="visiblePasswordField"
                                                                   managed="false"
                                                                   promptText="Enter your password"
                                                                   styleClass="input-field"
                                                                   visible="false" />

                                                        <PasswordField fx:id="passwordField"
                                                                       promptText="Enter your password"
                                                                       styleClass="input-field" />
                                                    </children>
                                                </StackPane>

                                                <Button fx:id="togglePasswordButton"
                                                        focusTraversable="false"
                                                        mnemonicParsing="false"
                                                        onAction="#togglePasswordVisibility"
                                                        styleClass="ghost-button"
                                                        text="View" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Label fx:id="feedbackLabel"
                                       minHeight="18.0"
                                       styleClass="feedback-label"
                                       wrapText="true" />

                                <Button maxWidth="1.7976931348623157E308"
                                        mnemonicParsing="false"
                                        onAction="#login"
                                        prefHeight="42.0"
                                        styleClass="primary-button"
                                        text="Log in" />

                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label styleClass="muted-label"
                                               text="Don't have an account?" />

                                        <Button mnemonicParsing="false"
                                                onAction="#openRegister"
                                                styleClass="link-button"
                                                text="Create account" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </GridPane>
    </center>
</BorderPane>