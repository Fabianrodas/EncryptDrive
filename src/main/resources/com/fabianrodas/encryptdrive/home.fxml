<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane id="root" fx:id="root" prefHeight="600.0" prefWidth="1000.0" styleClass="window-root" stylesheets="@../css/home.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fabianrodas.encryptdrive.HomeController">

    <top>
        <HBox id="titleBar" alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#beginDrag" prefHeight="38.0">

            <children>
                <Label styleClass="window-name" text="EncryptDrive" />

                <Region HBox.hgrow="ALWAYS" />

                <Button id="minimize" mnemonicParsing="false" onAction="#minimize" styleClass="window-control" text="—" />

                <Button id="close" mnemonicParsing="false" onAction="#close" styleClass="window-control" text="×" />
            </children>
        </HBox>
    </top>
</BorderPane>
